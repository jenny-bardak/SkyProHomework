# Служебные файлы Python и pytest не нужны в репозитории.
__pycache__/
*.pyc
.pytest_cache/

# Allure генерирует эти папки при запуске тестов.
allure-results/
allure-report/

# Локальные скриншоты и временные отчеты не нужны в публичном репозитории.
reports/

# В этом файле обычно лежат реальные токены и пароли.
# В GitHub его добавлять нельзя, чтобы не раскрыть доступы.
.env

# Локальная ссылка на bundled node_modules нужна только для генерации XLS.
node_modules/
node_modules

# Системные файлы macOS.
.DS_Store
