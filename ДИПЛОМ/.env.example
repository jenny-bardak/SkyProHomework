# Базовый адрес REST API YouGile.
# Для облачной версии чаще всего подходит такой вариант.
YOUGILE_API_URL=https://ru.yougile.com/api-v2

# Базовый адрес веб-версии YouGile.
YOUGILE_WEB_URL=https://ru.yougile.com

# API-токен YouGile. Его нужно получить в личном кабинете/через API.
# В реальном .env укажи значение без кавычек.
YOUGILE_TOKEN=put_your_token_here

# Учетные данные для UI-тестов.
# Их не нужно хранить прямо в коде.
YOUGILE_EMAIL=put_your_email_here
YOUGILE_PASSWORD=put_your_password_here

# Браузер для Selenium: chrome или firefox.
BROWSER=chrome

# Headless=true запускает браузер без окна.
# Для записи видеозащиты лучше поставить false.
HEADLESS=false
